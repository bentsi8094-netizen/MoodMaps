{
  "expo": {
    "name": "Mood Maps",
    "slug": "mood-maps",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/mood-maps-icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F0F4F8",
    "splash": {
      "image": "./assets/mood-maps-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moodmaps.app",
      "userInterfaceStyle": "light",
      "config": {
        "googleMapsApiKey": "AIzaSyDfh_ojB5d0L3Vs3Nu6k4berPbvRjzZvuI"
      }
    },
    "android": {
      "package": "com.moodmaps.app",
      "versionCode": 1,
      "userInterfaceStyle": "light",
      "permissions": [
        "INTERNET",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDfh_ojB5d0L3Vs3Nu6k4berPbvRjzZvuI"
        }
      }
    },
    "extra": {
      "apiUrl": "https://moodmaps-native.onrender.com",
      "eas": {
        "projectId": "b62bb1f0-70be-404e-9507-6b24f826e628"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "splash": {
        "image": "./assets/mood-maps-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-image"
    ]
  }
}